# Copy to .env and fill in values
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL_ID=C0123456789

# Optional — queue data directory (defaults to the install dir, same folder as bot.py)
# MERGE_QUEUE_DIR=/home/you/merge-queue
# PR_MERGED_FILE=/home/you/merge-queue/prs-merged.txt
# START_WORKER=false

# Deploy via Slack (/merge-deploy) — off by default
# DEPLOY_ENABLED=true
# DEPLOY_ALLOWED_USER_IDS=U01234567
# DEPLOY_BRANCH=main

# Optional
DEFAULT_REPO=GetStream/chat
MAX_RETRIES=3
POLL_INTERVAL=10
CHECK_INTERVAL=10
MERGE_METHOD=squash
