# Copy to .env and fill in values
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL_ID=C0123456789

# Optional — queue data directory (defaults to /srv/stream/merge-queue)
# MERGE_QUEUE_DIR=/srv/stream/merge-queue
# PR_MERGED_FILE=/srv/stream/merge-queue/prs-merged.txt
# START_WORKER=false
# DEPLOY_ALLOWED_USERS=U0123456789
# DEPLOY_GIT_BRANCH=main

# Optional
DEFAULT_REPO=GetStream/chat
MAX_RETRIES=5
POLL_INTERVAL=10
CHECK_INTERVAL=10
MERGE_METHOD=squash
