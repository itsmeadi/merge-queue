# Copy to .env and fill in values
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL_ID=C0123456789

# Optional — queue data directory (defaults to the install dir, same folder as bot.py)
# MERGE_QUEUE_DIR=/home/you/merge-queue
# PR_MERGED_FILE=/home/you/merge-queue/prs-merged.txt
# START_WORKER=false

# Deploy via Slack (/merge-deploy) — off by default
# DEPLOY_ENABLED=true
# DEPLOY_ALLOWED_USER_IDS=U01234567
# DEPLOY_BRANCH=main

# Optional — living queue board anchor (defaults to MERGE_QUEUE_DIR/queue-status.json)
# QUEUE_STATUS_FILE=/home/you/merge-queue/queue-status.json

# PR_TITLE_MAX_LEN=50   # max chars for title in Slack lines (default 50)

# Optional
DEFAULT_REPO=GetStream/chat
MAX_RETRIES=3
POLL_INTERVAL=10
CHECK_INTERVAL=10
MERGE_METHOD=squash

# Emoji reactions — upload custom emojis in Slack (Customize workspace → Add custom emoji)
# MERGE_REACTION_EMOJI=merge_bot   # react on a PR message to queue (default: merge_bot)
# MERGED_REACTION_EMOJI=merged     # bot adds to source message when PR merges (default: merged)
# MERGE_REACTION_ACK=true          # bot adds :white_check_mark:/:x:/:ghost: ack on enqueue (default: true)
